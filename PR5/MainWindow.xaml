<Window x:Class="PR5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Aquamarine"
        Title="Моя визитная карточка" Height="500" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="Даниил Дворников" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Junior WPF Developer" FontSize="14" Foreground="Gray"/>
            <Image Source="/resources/avatar.jpg" Width="100" Height="100" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBox x:Name="Name" Text="Введите ваше имя" Width="200" Margin="5" GotFocus="Name_GotFocus" LostFocus="Name_LostFocus"/>
            <TextBlock x:Name="GreetingTextBlock" Text="Добрый день!" FontSize="16" Margin="5" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="GreetButton" Content="Поприветствовать" Width="150" Height="30" Margin="5" Click="GreetButton_Click"/>
            <Button x:Name="ResetButton" Content="Сброс" Width="100" Height="30" Margin="5" Click="ResetButton_Click"/>
        </StackPanel>
    </Grid>
</Window>